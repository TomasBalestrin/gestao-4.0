# =============================================================
# Gestão 4.0 — Variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha os valores.
# NUNCA commite `.env.local`.
# =============================================================

# ----- Pública (cliente OK) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://gestao-4-0.vercel.app

# ----- Privada (servidor only — JAMAIS prefixar com NEXT_PUBLIC_) -----
SUPABASE_SERVICE_ROLE_KEY=

# Rate limiting (Upstash Redis) — opcional no MVP
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
